{
  "info": {
    "_postman_id": "fit4110-lab03-notification",
    "name": "FIT4110 Lab03 - Notification Contract Tests",
    "description": "Postman Collection cho A7 Notification Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.variables.set('traceId', 'fit4110-lab03-' + Date.now());",
          "pm.request.headers.upsert({ key: 'X-Trace-Id', value: pm.variables.get('traceId') });",
          "if (!pm.variables.get('idempotencyKey')) {",
          "  const uuid = require('uuid');",
          "  pm.variables.set('idempotencyKey', uuid.v4());",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "00_Health",
      "item": [
        {
          "name": "GET /health - service is alive",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "POST /notifications - send notification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{idempotencyKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/notifications",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "notifications"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"alertId\": \"0196fb3d-4ad7-7d1e-9f49-5d5148d2babc\",\n  \"channel\": \"EMAIL\",\n  \"recipient\": \"security@campus.local\",\n  \"message\": \"Phát hiện truy cập trái phép\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Response has notificationId', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('notificationId');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02_Auth",
      "item": [
        {
          "name": "POST /notifications - missing token is rejected",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{idempotencyKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/notifications",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "notifications"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"alertId\": \"0196fb3d-4ad7-7d1e-9f49-5d5148d2babc\",\n  \"channel\": \"EMAIL\",\n  \"recipient\": \"security@campus.local\",\n  \"message\": \"Phát hiện truy cập trái phép\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "if (env === 'mock') {",
                  "  pm.test('Skipped on mock', function () { pm.expect(true).to.eql(true); });",
                  "} else {",
                  "  pm.test('Missing token returns 401', function () { pm.expect([401, 403]).to.include(pm.response.code); });",
                  "}"
                ]
              }
            }
          ]
        },
