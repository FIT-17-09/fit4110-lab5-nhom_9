              ],
              "path": [
                "alerts",
                "0196fb3d-4ad7-7d1e-9f49-5d5148d2babc"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Consumer receives success from provider mock', function () { pm.expect(pm.response.code).to.eql(200); });",
                  "pm.test('Consumer can read alert fields', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json).to.have.property('severity');",
                  "});"
                ]
              }
            }
